# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_db
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password

# Teller mTLS cert (downloaded from Teller dashboard at signup).
# Store outside the repo or in a gitignored directory like .secrets/teller/.
TELLER_CERT_PATH=.secrets/teller/certificate.pem
TELLER_KEY_PATH=.secrets/teller/private_key.pem

# Per-enrollment access tokens issued by Teller Connect.
# Sandbox has one shared token; for real banks add one TELLER_TOKEN_<NAME> per enrollment.
TELLER_SANDBOX_ACCESS_TOKEN=test_token_xxxxxxxxxxxxx
# TELLER_TOKEN_CHASE=token_xxxxxxxxxxxxx
# TELLER_TOKEN_AMEX=token_xxxxxxxxxxxxx
