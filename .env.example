# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=dough_flow_db
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password

# Plaid API credentials (from https://dashboard.plaid.com/developers/keys)
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_production_or_sandbox_secret
PLAID_ENV=production

# Per-enrollment access tokens from Plaid Link.
# ingest_plaid.py discovers all env vars matching PLAID_TOKEN_<LABEL> and loops over them.
# Generate via: plaid_create_link_token.py → plaid_link.html → plaid_exchange_public_token.py
# PLAID_TOKEN_WEALTHFRONT=access-production-xxxxxxxxxxxxx
# PLAID_TOKEN_CHASE=access-production-xxxxxxxxxxxxx
# PLAID_TOKEN_AMEX=access-production-xxxxxxxxxxxxx
# PLAID_TOKEN_CITI=access-production-xxxxxxxxxxxxx
# PLAID_TOKEN_SANDBOX=access-sandbox-xxxxxxxxxxxxx
