# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=dough_flow_db
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password

# Plaid API credentials (from https://dashboard.plaid.com/developers/keys)
PLAID_CLIENT_ID=your_client_id
PLAID_SECRET=your_production_or_sandbox_secret
PLAID_ENV=production

# Airflow secrets (Docker only)
# Generate FERNET_KEY with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# AIRFLOW_SECRET_KEY can be any random string
FERNET_KEY=your_fernet_key
AIRFLOW_SECRET_KEY=your_airflow_secret_key

# Per-enrollment access tokens from Plaid Link.
# ingest_plaid.py discovers all env vars matching PLAID_TOKEN_<LABEL> and loops over them.
# Generate via: plaid_create_link_token.py → plaid_link.html → plaid_exchange_public_token.py
# PLAID_TOKEN_BANK1=access-production-xxxxxxxxxxxxx
# PLAID_TOKEN_BANK2=access-production-xxxxxxxxxxxxx
# PLAID_TOKEN_SANDBOX=access-sandbox-xxxxxxxxxxxxx
